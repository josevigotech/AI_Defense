import pandas as pd
from sklearn.preprocessing import StandardScaler
from sklearn.ensemble import IsolationForest
import joblib
import logging
import smtplib
from email.mime.text import MIMEText
import os
import re

# ------------------------------
# 0. Logging profesional
# ------------------------------
logging.basicConfig(
    filename='ia_defensiva.log',
    level=logging.INFO,
    format='%(asctime)s - %(levelname)s - %(message)s'
)

# ------------------------------
# 1. Procesamiento de Logs Reales (Nuevo)
# ------------------------------
def extraer_datos_logs():
    eventos = []
    
    # Procesar auth.log (Intentos de login)
    # Ruta basada en tu estructura de archivos: log_analyzer/auth.log
    if os.path.exists('log_analyzer/auth.log'):
        with open('log_analyzer/auth.log', 'r') as f:
            for linea in f:
                if "authentication failure" in linea:
                    hora = int(linea.split()[2].split(':')[0])
                    es_root = 1 if "user=root" in linea else 0
                    eventos.append({'hora': hora, 'tipo': 1, 'critico': es_root, 'puerto': 0})
    
    # Procesar ufw.log (Bloqueos de firewall)
    if os.path.exists('log_analyzer/ufw.log'):
        with open('log_analyzer/ufw.log', 'r') as f:
            for linea in f:
                if "[UFW BLOCK]" in linea:
                    hora = int(linea.split()[2].split(':')[0])
                    # Extraer puerto si existe (DPT=...)
                    puerto_match = re.search(r'DPT=(\d+)', linea)
                    puerto = int(puerto_match.group(1)) if puerto_match else 0
                    eventos.append({'hora': hora, 'tipo': 2, 'critico': 0, 'puerto': puerto})

    # Si no hay archivos, creamos un DF vacío con la estructura correcta
    if not eventos:
        return pd.DataFrame(columns=['hora', 'tipo', 'critico', 'puerto'])
        
    return pd.DataFrame(eventos)

# Cargar los datos desde los archivos del ZIP
data = extraer_datos_logs()

# Definir las características para la IA
features = ['hora', 'tipo', 'critico', 'puerto']

# ------------------------------
# 2. Preprocesamiento
# ------------------------------
if not data.empty:
    scaler = StandardScaler()
    data_scaled = scaler.fit_transform(data[features])

    # ------------------------------
    # 3. Entrenar modelo
    # ------------------------------
    # Ajustamos la contaminación (proporción de anomalías esperadas) al 5%
    model = IsolationForest(n_estimators=100, contamination=0.05, random_state=42)
    model.fit(data_scaled)

    # ------------------------------
    # 4. Detectar anomalías
    # ------------------------------
    data['anomaly'] = model.predict(data_scaled)
    data['score'] = model.decision_function(data_scaled)

    logging.info("Evaluación de logs reales completada")
else:
    logging.error("No se encontraron datos en los logs para procesar.")

# ------------------------------
# 5. Alertas con filtrado por score
# ------------------------------
def enviar_alerta(evento):
    try:
        smtp_user = os.getenv("SMTP_USER")
        smtp_pass = os.getenv("SMTP_PASS")
        
        if not smtp_user or not smtp_pass:
            logging.error("Credenciales SMTP no configuradas.")
            return

        msg = MIMEText(f"Evento anómalo real detectado en logs:\n{evento}")
        msg['Subject'] = 'ALERTA DE SEGURIDAD - IA DEFENSIVA'
        msg['From'] = smtp_user
        msg['To'] = 'admin@empresa.com'

        with smtplib.SMTP('smtp.gmail.com', 587) as server:
            server.starttls()
            server.login(smtp_user, smtp_pass)
            server.send_message(msg)
            
        logging.warning(f"Alerta enviada: {evento}")
    except Exception as e:
        logging.error(f"Error enviando alerta: {e}")

# Filtrar alertas (si el score es muy bajo, es un ataque más probable)
UMBRAL_SCORE = -0.15

if not data.empty:
    for _, row in data.iterrows():
        if row['anomaly'] == -1 and row['score'] < UMBRAL_SCORE:
            enviar_alerta(row.to_dict())

# ------------------------------
# 6. Guardar modelo + scaler
# ------------------------------
if not data.empty:
    joblib.dump({
        "model": model,
        "scaler": scaler,
        "features": features
    }, "ia_defensiva_real.pkl")
    logging.info("Modelo entrenado con logs reales guardado correctamente")
